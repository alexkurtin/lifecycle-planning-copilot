# Streamlit secrets — TEMPLATE (safe to commit; contains no real key)
# ====================================================================
# This is the exact format Streamlit expects for secrets.
#
# ON STREAMLIT COMMUNITY CLOUD (how your interviewer's link gets a key):
#   App menu -> Settings -> Secrets -> paste the line below with your
#   real key -> Save. Keep it at the TOP with NO [section] header:
#   root-level secrets are exposed as environment variables, which is
#   how this app reads the key (os.getenv("ANTHROPIC_API_KEY")).
#
# LOCALLY you do NOT need this file — the app already reads your key
# from .env. Only copy this to ".streamlit/secrets.toml" (and never
# commit it) if you prefer Streamlit's secret store over .env.

ANTHROPIC_API_KEY = "sk-ant-your-key-here"
